{{!
    @template theme_veraxity/frontpage

    Marketing-style nav + footer chrome for the front page, wrapping
    output.main_content (the hero/programs/etc body built by
    theme_veraxity\output\core\course_renderer::frontpage()).

    Example context (json):
    {
        "output": {
            "doctype": "<!DOCTYPE html>",
            "page_title": "Veraxity Academy",
            "favicon": "favicon.ico",
            "main_content": "<h1>Front page body</h1>"
        },
        "navwordmark": "Veraxity <span>Academy</span>",
        "loginlabel": "Log in",
        "loginurl": "https://example.com/login/index.php",
        "enrollurl": "https://example.com/login/signup.php",
        "courseindexurl": "https://example.com/course/index.php",
        "footercopyright": "© 2026 Veraxity Academy"
    }
}}
{{> theme_boost/head }}

<body {{{ bodyattributes }}}>
{{> core/local/toast/wrapper}}
{{{ output.standard_top_of_body_html }}}

{{!
    Not #page-wrapper: that id carries Boost's sticky-footer CSS
    (height:100%; display:flex; flex-direction:column), which squeezes this
    nav via flex-shrink and breaks its position:sticky against a container
    that never grows past one viewport height.
}}
<div class="veraxity-lp-page-wrapper">

<nav class="veraxity-lp-nav">
    <a href="#top" class="veraxity-lp-nav__wordmark">{{{ navwordmark }}}</a>
    <div class="veraxity-lp-nav__links">
        <a href="#programs">{{#str}} navprograms, theme_veraxity {{/str}}</a>
        <a href="#how-it-works">{{#str}} navhowitworks, theme_veraxity {{/str}}</a>
        <a href="#why">{{#str}} navplatform, theme_veraxity {{/str}}</a>
        <a href="#contact">{{#str}} navcontact, theme_veraxity {{/str}}</a>
    </div>
    <div class="veraxity-lp-nav__actions">
        <a href="{{{ loginurl }}}" class="veraxity-lp-btn veraxity-lp-btn--ghost">{{{ loginlabel }}}</a>
        <a href="{{{ enrollurl }}}" class="veraxity-lp-btn veraxity-lp-btn--gold">{{#str}} navenroll, theme_veraxity {{/str}}</a>
    </div>
    <button class="veraxity-lp-nav__toggle" id="veraxityLpNavToggle" aria-label="{{#str}} togglemenu, theme_veraxity {{/str}}">
        <span></span><span></span><span></span>
    </button>
    <div class="veraxity-lp-nav__mobile-panel" id="veraxityLpNavMobilePanel">
        <a href="#programs">{{#str}} navprograms, theme_veraxity {{/str}}</a>
        <a href="#how-it-works">{{#str}} navhowitworks, theme_veraxity {{/str}}</a>
        <a href="#why">{{#str}} navplatform, theme_veraxity {{/str}}</a>
        <a href="#contact">{{#str}} navcontact, theme_veraxity {{/str}}</a>
        <div class="veraxity-lp-nav__actions">
            <a href="{{{ loginurl }}}" class="veraxity-lp-btn veraxity-lp-btn--ghost">{{{ loginlabel }}}</a>
            <a href="{{{ enrollurl }}}" class="veraxity-lp-btn veraxity-lp-btn--gold">{{#str}} navenroll, theme_veraxity {{/str}}</a>
        </div>
    </div>
</nav>

{{{ output.main_content }}}

<footer class="veraxity-lp-footer">
    <div class="veraxity-lp-footer__inner">
        <div class="veraxity-lp-footer__grid">
            <div class="veraxity-lp-footer__col">
                <a href="#top" class="veraxity-lp-nav__wordmark">{{{ navwordmark }}}</a>
                <p class="veraxity-lp-footer__brand-desc">{{#str}} footerbranddesc, theme_veraxity {{/str}}</p>
            </div>
            <div class="veraxity-lp-footer__col">
                <div class="veraxity-lp-footer__col-title">{{#str}} footercolprograms, theme_veraxity {{/str}}</div>
                <a href="#programs">{{#str}} herobrowseprograms, theme_veraxity {{/str}}</a>
                <a href="{{{ courseindexurl }}}">{{#str}} programviewall, theme_veraxity {{/str}}</a>
            </div>
            <div class="veraxity-lp-footer__col">
                <div class="veraxity-lp-footer__col-title">{{#str}} footercolplatform, theme_veraxity {{/str}}</div>
                <a href="#how-it-works">{{#str}} navhowitworks, theme_veraxity {{/str}}</a>
                <a href="#why">{{#str}} footerforinstructors, theme_veraxity {{/str}}</a>
                <a href="#why">{{#str}} footerforadmins, theme_veraxity {{/str}}</a>
            </div>
            <div class="veraxity-lp-footer__col">
                <div class="veraxity-lp-footer__col-title">{{#str}} footercolacademy, theme_veraxity {{/str}}</div>
                <a href="#contact">{{#str}} navcontact, theme_veraxity {{/str}}</a>
                <a href="{{{ enrollurl }}}">{{#str}} navenroll, theme_veraxity {{/str}}</a>
                <a href="{{{ loginurl }}}">{{{ loginlabel }}}</a>
            </div>
        </div>
        <div class="veraxity-lp-footer__bottom">
            <div>{{{ footercopyright }}}</div>
        </div>
    </div>
</footer>

<button class="veraxity-lp-scrolltop" id="veraxityLpScrollTop" aria-label="{{#str}} scrolltotop, theme_veraxity {{/str}}">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
</button>

{{!
    standard_footer_html() carries real plugin-injected links (data privacy
    retention summary, mobile app download) via the
    before_standard_footer_html_generation hook — kept, not stripped, but
    wrapped so it reads as part of the dark footer instead of an unstyled
    white strip tacked on after it.
}}
<div class="veraxity-lp-footer-extra">
{{{ output.standard_footer_html }}}
</div>
{{{ output.standard_end_of_body_html }}}
</div>

</body>
</html>
{{#js}}
require(['jquery'], function($) {
    var navToggle = document.getElementById('veraxityLpNavToggle');
    var navPanel = document.getElementById('veraxityLpNavMobilePanel');
    if (navToggle && navPanel) {
        navToggle.addEventListener('click', function () {
            navPanel.classList.toggle('open');
        });
        navPanel.querySelectorAll('a').forEach(function (a) {
            a.addEventListener('click', function () { navPanel.classList.remove('open'); });
        });
    }

    var fadeEls = document.querySelectorAll('.veraxity-lp-fade-up');
    if (window.IntersectionObserver && fadeEls.length) {
        var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                    entry.target.classList.add('in-view');
                    observer.unobserve(entry.target);
                }
            });
        }, {threshold: 0.15});
        fadeEls.forEach(function (el) { observer.observe(el); });
    }

    var scrollTopBtn = document.getElementById('veraxityLpScrollTop');
    if (scrollTopBtn) {
        window.addEventListener('scroll', function () {
            scrollTopBtn.classList.toggle('visible', window.scrollY > 480);
        });
        scrollTopBtn.addEventListener('click', function () {
            window.scrollTo({top: 0, behavior: 'smooth'});
        });
    }
});
{{/js}}
