{{!
    @template theme_veraxity/theme_boost/navbar

    Override of theme_boost/navbar — identical to core except the plain
    site-name text is replaced with the same branded wordmark used on the
    front page (Site admin > Themes can keep a custom logo working as-is;
    only the no-logo text fallback changes). Everything else (course index
    toggle, search, language menu, user menu) is untouched core markup.

    Example context (json):
    {
        "output": {
            "should_display_navbar_logo": false,
            "get_compact_logo_url": "http://placekitten.com/50/50",
            "search_box": "<div><input type='text'></div>",
            "user_menu": "<div class='dropdown'>John Doe</div>"
        },
        "config": {
            "wwwroot": "#",
            "homeurl": "/my/"
        },
        "sitename": "Moodle Site"
    }
}}
<nav class="navbar fixed-top bg-body navbar-expand veraxity-navbar" aria-label="{{#str}}sitemenubar, admin{{/str}}">
    <div class="container-fluid">
        <button class="navbar-toggler aabtn d-block d-md-none px-1 my-1 border-0" data-toggler="drawers" data-action="toggle" data-target="theme_boost-drawers-primary">
            <span class="navbar-toggler-icon"></span>
            <span class="visually-hidden">{{#str}}sidepanel, core{{/str}}</span>
        </button>

        <a href="{{{ config.homeurl }}}" class="navbar-brand d-none d-md-flex align-items-center m-0 me-4 p-0 aabtn">

            {{# output.should_display_navbar_logo }}
                <img src="{{output.get_compact_logo_url}}" class="logo me-1" alt="{{sitename}}">
            {{/ output.should_display_navbar_logo }}
            {{^ output.should_display_navbar_logo }}
                <span class="veraxity-navbar-brand">{{#str}} navwordmark, theme_veraxity {{/str}}</span>
            {{/ output.should_display_navbar_logo }}
        </a>
        {{#primarymoremenu}}
            <div class="primary-navigation">
                {{> core/moremenu}}
            </div>
        {{/primarymoremenu}}

        {{# output.page_heading_menu}}
            <ul class="navbar-nav d-none d-md-flex my-1 px-1">
                <!-- page_heading_menu -->
                {{{ output.page_heading_menu }}}
            </ul>
        {{/output.page_heading_menu}}

        <div id="usernavigation" class="navbar-nav ms-auto h-100">
            {{# output.search_box }}
                {{{ output.search_box }}}
                <div class="divider border-start h-75 align-self-center mx-1"></div>
            {{/output.search_box}}
            {{#langmenu}}
                {{> theme_boost/language_menu }}
                <div class="divider border-start h-75 align-self-center mx-1"></div>
            {{/langmenu}}
            {{{ output.edit_switch }}}
            {{# output.navbar_plugin_output }}
            {{{ . }}}
                <div class="divider border-start h-75 align-self-center mx-1"></div>
            {{/output.navbar_plugin_output}}
            {{#usermenu}}
                <div class="d-flex align-items-stretch usermenu-container" data-region="usermenu">
                    {{> core/user_menu }}
                </div>
            {{/usermenu}}
        </div>
    </div>
</nav>

{{> theme_boost/primary-drawer-mobile }}
